# Copy to .env and fill real values. NEVER commit real .env (gitignored).
#
# tripwire currently calls models through Groq (free tier, OpenAI-compatible,
# supports tool calling). Swap in another provider later by changing these.

GROQ_API_KEY=

# Groq's OpenAI-compatible endpoint (fixed — used as the OpenAI client base_url).
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Model to evaluate. Must support tool/function calling for the agent loop.
# e.g. llama-3.3-70b-versatile
GROQ_MODEL=llama-3.3-70b-versatile

# --- Notes for later ---
# AgentDojo has no native `groq` provider. Groq is OpenAI-compatible, so wire it
# in the same way as AgentDojo's `together` branch: an openai.OpenAI client with
# base_url=GROQ_BASE_URL and api_key=GROQ_API_KEY. tripwire's own adapters use
# the same OpenAI-client-with-base_url pattern.
#
# Other providers can drop in here when needed (Azure OpenAI for GPT, Vertex for
# Gemini/Claude, AWS Bedrock). Each has its own creds.
